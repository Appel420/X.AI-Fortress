class Validator {
    static async hash(file){
        return new Promise(r=> {
            const rd = new FileReader();
            rd.onload = ()=> {
                crypto.subtle.digest('SHA-3-512', new Uint8Array(rd.result))
                .then(h=> {
                    r(Array.from(new Uint8Array(h)).map(b=>b.toString(16).padStart(2,'0')).join(''))
                });
            };
            rd.readAsArrayBuffer(file);
        });
    }
    static bad(content){
        return ['pickle','os.system','subprocess','eval','exec','__import__','fetch','xmlhttprequest','base64','shell']
            .filter(w=>content.toLowerCase().includes(w)).length;
    }
    static async run(files){
        const hashes = await Promise.all(files.map(f=>this.hash(f)));
        const bad = files.filter(f=> {
            const cnt = new Blob( ).text();
            return this.bad(cnt) || f.name.includes('.js|.py');
        });
        document.body.innerHTML = bad.length ? '💀 COMPROMISED' : '✅ CLEAN';
    }
}
