import os
import tarfile
import hashlib
from pathlib import Path

def seal_repo(archive_name="sovereignty-ai.tar.gz", checksum_name="sovereignty-ai.sha3-512"):
    """
    Creates a gzipped tar archive of the current directory and generates its SHA3-512 checksum.

    Args:
        archive_name (str): The name of the tar.gz archive file to create.
        checksum_name (str): The name of the checksum file to create.
    """
    try:
        # Use a context manager for the tar file to ensure it's closed properly
        with tarfile.open(archive_name, "w:gz") as tar:
            # Iterate through all files and directories recursively
            for item in Path().rglob("*"):
                # Only add files to the archive
                if item.is_file():
                    tar.add(item)
                    print(f"Added: {item}") # Optional: provide feedback

        # Calculate the SHA3-512 digest
        # Use a context manager for reading the file to ensure it's closed
        with open(archive_name, "rb") as f:
            file_content = f.read()
            digest = hashlib.sha3_512(file_content).hexdigest() # Corrected hashlib function name

        # Write the checksum to a file
        # Use a context manager for writing to the file
        with open(checksum_name, "w") as f:
            f.write(digest)

        print(f"Successfully created '{archive_name}' and '{checksum_name}'.")

    except FileNotFoundError:
        print("Error: Could not find files to archive. Ensure you are in the correct directory.")
    except PermissionError:
        print("Error: Permission denied. Check file and directory permissions.")
    except Exception as e:
        print(f"An unexpected error occurred: {e}")

if __name__ == "__main__":
    seal_repo()
