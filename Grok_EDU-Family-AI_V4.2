async function sealAnswersBlob(answersText) {
  requireRole("teacher");

  const encoder = new TextEncoder();
  const data = encoder.encode(answersText);

  const hash = await crypto.subtle.digest("SHA-512", data);
  const hashHex = [...new Uint8Array(hash)]
    .map(b => b.toString(16).padStart(2,"0"))
    .join("");

  const seal = "sealed-" + hashHex.slice(0,32);

  seals.push({
    ts: new Date().toISOString(),
    seal,
    intent: "TEACHER_ANSWER_KEY"
  });

  renderChain();
  logChat("Answer key sealed.", "bot");
}

