document.addEventListener("DOMContentLoaded", () => {
  document.body.style.background="#020617"; // instant black
  // Kid Mode — All in one
  const bg = prompt("Background? (blue, pink, green, dark, rainbow)");
  const colors = {
    blue: "linear-gradient(to bottom, #0074D9, #0a6a3a)",
    pink: "linear-gradient(to bottom, #FF69B4, #C71585)",
    green: "linear-gradient(to bottom, #228B22, #006400)",
    dark: "#020617",
    rainbow: "linear-gradient(90deg, red, orange, yellow, green, blue, indigo, violet)"
  };
  document.body.style.background = colors[bg] || "#020617";
  document.body.style.backgroundSize = "cover";

  // Font
  const fontChoice = prompt("Font? (normal, cute, bold, dreamy, comic)", "normal").toLowerCase();
  const fonts = {
    normal: "system-ui",
    cute: "Comic Sans MS, cursive",
    bold: "Impact, sans-serif",
    dreamy: "Brush Script MT, cursive",
    comic: "Courier New, monospace"
  };
  document.body.style.fontFamily = fonts[fontChoice] || "system-ui";
  document.body.style.fontSize = "16px";

  // Photo
  const addPhoto = prompt("Add photo? (yes/no)", "no");
  if(addPhoto==="yes"){
    const fileInp=document.createElement("input");
    fileInp.type="file";
    fileInp.accept="image/*";
    fileInp.onchange=e=>{
      const reader=new FileReader();
      reader.onload=ev=>{
        const img=new Image();
        img.src=ev.target.result;
        img.style.width="150px";
        img.style.borderRadius="50%";
        img.style.float="right";
        img.style.margin="10px";
        document.body.insertBefore(img,document.body.firstChild);
      };
      reader.readAsDataURL(e.target.files[0]);
    };
    fileInp.click();
  }
});
</script>
