.card {background:var(--card);border:1px solid #222;border-radius:8px;padding:16px;margin:16px 0;}
button {background:var(--txt);color:var(--bg);border:none;padding:6px 10px;border-radius:4px;cursor:pointer;}
button:active {background:#777;}
.hint-bar {font-size:1rem;margin:10px 0;color:#0f9;}
#chat {height:300px;overflow-y:auto;padding:8px;background:#000;color:#0f9;border:1px solid #222;}
.msg {margin:4px 0;}
</style>
</head>
<body>

<h1>🧠 Grok EDU + Family AI</h1>
<div class="hint-bar">💡 Hints earned: <span id="hint-count">0</span></div>

<div class="card">
  <h3>⚙️ Settings</h3>
  <label><input type="checkbox" id="ai-main" checked> All AIs</label><br>
  <label><input type="radio" name="model" value="edu"> EDU Mode</label><br>
  <label><input type="radio" name="model" value="family"> Family Mode</label><br>
  <label><input type="radio" name="model" value="off-record"> Off-Record (nuke)</label><br>
  <button onclick="earnHint()">+ Earn Hint</button>
  <button onclick="spendHint()">Use Hint</button>
</div>

<div class="card">
  <h3>🧑‍🏫 EDU / Family</h3>
  <div id="chat"></div>
  <input id="msg" placeholder="study / note / /hint pi" autofocus>
</div>

<script>
// --- Blake3 stub ---
function blake3(i){return 'b3'+Math.random().toString(36).slice(2,6);}

// --- Hints ---
const hints = {bank:parseInt(localStorage.getItem('hint_bank')||'0',10)};
function updateHintBar(){document.getElementById('hint-count').textContent=hints.bank;}
function earnHint(){hints.bank++;localStorage.setItem('hint_bank',hints.bank);updateHintBar();}
function spendHint(){if(hints.bank>0){hints.bank--;localStorage.setItem('hint_bank',hints.bank);updateHintBar();alert('Hint used.');}else alert('No hints.');}

// --- Chat & Logic ---
const chat=document.getElementById('chat');
function msg(t,c='system'){const m=document.createElement('div');m.textContent=t;m.className=c;chat.appendChild(m);chat.scrollTop=9999;}
document.getElementById('msg').onkeypress=e=>{
  if(e.key!=='Enter')return;
  const i=e.target.value.trim();e.target.value='';
  msg(i,'user');
  if(i==='/hint' && hints.bank>0){
    const top=i.slice(6)||'pi';
    msg('Pi = C/d... starts with 3.','hint');
    spendHint();
  }else if(i.startsWith('/hint ')){
    spendHint();
    msg('Hint earned. Total: '+hints.bank,'system');
  }else if(i.startsWith('/nuke')){
    localStorage.clear();
    msg('All memory burned. Hash: '+blake3('nuke'),"warn");
    document.getElementById('ai-main').checked=false;
  }else if(i==='study'){
    msg('Go start your timer. Focus on the math.','system');
  }else if(i==='note'){
    const n=prompt('Note:');
    if(n) msg('Saved: '+n);
  }else{
    msg('Got it. Locked in.','system');
  }
};

// --- AI Toggle ---
document.getElementById('ai-main').onchange=()=>{if(!event.target.checked)msg('AI OFFLINE. All systems silent.');};

// --- Off-Record ---
document.querySelectorAll('input ').forEach(r=>{r.onchange=()=>{if(r.value==='off-record'){localStorage.clear();msg('OFF-RECORD: memory erased. Hash burned: '+blake3('off'),'warn');}}});

// --- Init ---
msg('Sovereign mode active. You control me.'); updateHintBar();
</script>
</body>
</html>
