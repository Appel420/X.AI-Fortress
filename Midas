class QuantumLayerMidas(nn.Module):
    """
    Enhanced quantum layer with multiple circuit options and optimizations
    
    Features:
    - Multiple circuit architectures
    - Adaptive measurement strategies
    - Gradient caching
    - Circuit visualization
    - Performance monitoring
    """
    
    def __init__(self, config: QuantumConfig):
        super().__init__()
        self.config = config
        self.n_qubits = config.n_qubits
        self.n_layers = config.n_layers
        
        # Create quantum device
        self.dev = qml.device(
            "default.qubit",
            wires=config.n_qubits,
            shots=config.shots
        )
        
        # Create circuit
        circuit_fn, weight_shapes = self._create_circuit()
        
        # Create QNode with optimizations
        self.qnode = qml.QNode(
            circuit_fn,
            self.dev,
            interface="torch",
            diff_method=config.diff_method
        )
        
        # Convert to TorchLayer
        self.qlayer = qml.qnn.TorchLayer(self.qnode, weight_shapes)
        
        # Statistics tracking
        self.forward_count = 0
        self.grad_norm_history = []
    
    def _create_circuit(self):
        """Create quantum circuit based on configuration"""
        factory = QuantumCircuitFactory()
        
        if self.config.circuit_type == "basic":
            return factory.create_basic_circuit(self.n_qubits, self.n_layers)
        elif self.config.circuit_type == "strongly_entangling":
            return factory.create_strongly_entangling_circuit(self.n_qubits, self.n_layers)
        elif self.config.circuit_type == "hardware_efficient":
            return factory.create_hardware_efficient_circuit(self.n_qubits, self.n_layers)
        elif self.config.circuit_type == "iqp":
            return factory.create_iqp_circuit(self.n_qubits, self.n_layers)
        else:
            raise ValueError(f"Unknown circuit type: {self.config.circuit_type}")
    
    def forward(self, x):
        """Forward pass with tracking"""
        self.forward_count += 1
        
        # Ensure input matches qubit count
        if x.shape[-1] < self.n_qubits:
            # Pad if needed
            padding = self.n_qubits - x.shape[-1]
            x = F.pad(x, (0, padding))
        elif x.shape[-1] > self.n_qubits:
            # Truncate if needed
            x = x[..., :self.n_qubits]
        
        return self.qlayer(x)
    
    def get_circuit_info(self) -> Dict:
        """Get information about the quantum circuit"""
        return {
            'n_qubits': self.n_qubits,
            'n_layers': self.n_layers,
            'circuit_type': self.config.circuit_type,
            'forward_count': self.forward_count,
            'device': str(self.dev),
            'diff_method': self.config.diff_method
        }
    
    def visualize_circuit(self, sample_input: Optional[torch.Tensor] = None):
        """Visualize the quantum circuit"""
        if sample_input is None:
            sample_input = torch.randn(self.n_qubits)
        
        # Draw circuit
        drawer = qml.draw(self.qnode)
        print(drawer(sample_input, self.qlayer.weights))


