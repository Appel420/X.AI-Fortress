class QuantumCircuitFactory:
    """Factory for creating different quantum circuit architectures"""
    
    @staticmethod
    def create_basic_circuit(n_qubits: int, n_layers: int):
        """Basic variational circuit with RY rotations and CNOT entanglement"""
        def circuit(inputs, weights):
            # Encoding layer
            for i in range(n_qubits):
                qml.RY(inputs[i], wires=i)
            
            # Variational layers
            for j in range(n_layers):
                # Entanglement
                qml.broadcast(qml.CNOT, wires=range(n_qubits), pattern="ring")
                # Rotations
                for i in range(n_qubits):
                    qml.RY(weights[j, i, 0], wires=i)
                    qml.RZ(weights[j, i, 1], wires=i)
            
            return [qml.expval(qml.PauliZ(i)) for i in range(n_qubits)]
        
        return circuit, {"weights": (n_layers, n_qubits, 2)}
    
    @staticmethod
    def create_strongly_entangling_circuit(n_qubits: int, n_layers: int):
        """Strongly entangling layers with all-to-all connectivity"""
        def circuit(inputs, weights):
            # Amplitude encoding
            qml.AmplitudeEmbedding(
                features=inputs,
                wires=range(n_qubits),
                normalize=True,
                pad_with=0.0
            )
            
            # Strongly entangling layers
            qml.StronglyEntanglingLayers(
                weights=weights,
                wires=range(n_qubits)
            )
            
            return [qml.expval(qml.PauliZ(i)) for i in range(n_qubits)]
        
        return circuit, {"weights": (n_layers, n_qubits, 3)}
    
    @staticmethod
    def create_hardware_efficient_circuit(n_qubits: int, n_layers: int):
        """Hardware-efficient ansatz optimized for near-term devices"""
        def circuit(inputs, weights):
            # Encoding
            for i in range(n_qubits):
                qml.RY(inputs[i], wires=i)
            
            for j in range(n_layers):
                # Two-qubit gates (nearest neighbor)
                for i in range(n_qubits - 1):
                    qml.CZ(wires=[i, i + 1])
                
                # Single-qubit rotations
                for i in range(n_qubits):
                    qml.RY(weights[j, i, 0], wires=i)
                    qml.RZ(weights[j, i, 1], wires=i)
            
            return [qml.expval(qml.PauliZ(i)) for i in range(n_qubits)]
        
        return circuit, {"weights": (n_layers, n_qubits, 2)}
    
    @staticmethod
    def create_iqp_circuit(n_qubits: int, n_layers: int):
        """IQP-inspired circuit with diagonal gates"""
        def circuit(inputs, weights):
            # Hadamard layer
            for i in range(n_qubits):
                qml.Hadamard(wires=i)
            
            # IQP layers
            for j in range(n_layers):
                # Diagonal gates
                for i in range(n_qubits):
                    qml.RZ(inputs[i] * weights[j, i], wires=i)
                
                # Entanglement
                for i in range(n_qubits - 1):
                    qml.CZ(wires=[i, i + 1])
            
            return [qml.expval(qml.PauliZ(i)) for i in range(n_qubits)]
        
        return circuit, {"weights": (n_layers, n_qubits)}


