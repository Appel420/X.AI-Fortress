class TemporalAttention(nn.Module):
    """Temporal self-attention for EEG signals"""
    
    def __init__(self, channels: int, reduction: int = 8):
        super().__init__()
        self.channels = channels
        
        self.query = nn.Conv1d(channels, channels // reduction, 1)
        self.key = nn.Conv1d(channels, channels // reduction, 1)
        self.value = nn.Conv1d(channels, channels, 1)
        self.gamma = nn.Parameter(torch.zeros(1))
    
    def forward(self, x):
        """
        Args:
            x: (batch, channels, time)
        """
        batch_size, C, T = x.size()
        
        # Compute attention
        query = self.query(x).view(batch_size, -1, T).permute(0, 2, 1)  # (B, T, C')
        key = self.key(x).view(batch_size, -1, T)  # (B, C', T)
        
        attention = torch.bmm(query, key)  # (B, T, T)
        attention = F.softmax(attention, dim=-1)
        
        # Apply attention
        value = self.value(x).view(batch_size, -1, T)  # (B, C, T)
        out = torch.bmm(value, attention.permute(0, 2, 1))  # (B, C, T)
        out = out.view(batch_size, C, T)
        
        # Residual connection with learnable weight
        out = self.gamma * out + x
        
        return out


