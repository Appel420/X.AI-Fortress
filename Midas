@dataclass
class QuantumConfig:
    """Configuration for quantum layers"""
    n_qubits: int = 4
    n_layers: int = 2
    circuit_type: str = "strongly_entangling"  # Options: basic, strongly_entangling, hardware_efficient
    measurement: str = "expval"  # Options: expval, probs, sample
    diff_method: str = "best"  # Options: best, parameter-shift, backprop, adjoint
    shots: Optional[int] = None  # None for exact simulation
    
    def __post_init__(self):
        valid_circuits = ["basic", "strongly_entangling", "hardware_efficient", "iqp", "custom"]
        if self.circuit_type not in valid_circuits:
            raise ValueError(f"circuit_type must be one of {valid_circuits}")


