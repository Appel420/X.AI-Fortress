class QuantumEEGNetMidas(nn.Module):
    """
    Enhanced Quantum-Classical Hybrid EEGNet with Midas Touch ✨
    
    Features:
    - Advanced quantum circuit integration
    - Optional attention mechanisms
    - Residual connections
    - Comprehensive model analytics
    - Beautiful model summaries
    - Built-in interpretability
    
    Args:
        eeg_config: EEGNet architecture configuration
        quantum_config: Quantum layer configuration
        input_channels: Number of EEG channels (electrodes)
        input_length: Length of EEG signal
    """
    
    def __init__(
        self,
        eeg_config: Optional[EEGNetConfig] = None,
        quantum_config: Optional[QuantumConfig] = None,
        input_channels: int = 22,
        input_length: int = 1000
    ):
        super().__init__()
        
        # Use default configs if not provided
        self.eeg_config = eeg_config or EEGNetConfig()
        self.quantum_config = quantum_config or QuantumConfig()
        
        self.input_channels = input_channels
        self.input_length = input_length
        
        # Unpack EEG config
        F1 = self.eeg_config.F1
        D = self.eeg_config.D
        F2 = self.eeg_config.F2
        
        # ====================================================================
        # Block 1: Temporal Convolution
        # ====================================================================
        self.block1 = nn.Sequential(OrderedDict([
            ('conv1', nn.Conv2d(1, F1, (1, self.eeg_config.kernel_length),
                               padding=(0, self.eeg_config.kernel_length // 2),
                               bias=False)),
            ('bn1', nn.BatchNorm2d(F1) if self.eeg_config.use_batch_norm else nn.Identity()),
        ]))
        
        # ====================================================================
        # Block 2: Spatial Convolution (Depthwise)
        # ====================================================================
        self.block2 = nn.Sequential(OrderedDict([
            ('conv2', nn.Conv2d(F1, F1 * D, (input_channels, 1), groups=F1, bias=False)),
            ('bn2', nn.BatchNorm2d(F1 * D) if self.eeg_config.use_batch_norm else nn.Identity()),
            ('pool1', nn.AvgPool2d((1, self.eeg_config.pool_size_1))),
            ('dropout1', nn.Dropout(self.eeg_config.dropout_rate)),
        ]))
        
        # ====================================================================
        # Block 3: Separable Convolution
        # ====================================================================
        self.block3_depthwise = nn.Sequential(OrderedDict([
            ('conv3', nn.Conv2d(F1 * D, F1 * D, (1, 16), padding=(0, 8),
                               groups=F1 * D, bias=False)),
            ('bn3', nn.BatchNorm2d(F1 * D) if self.eeg_config.use_batch_norm else nn.Identity()),
        ]))
        
        self.block3_pointwise = nn.Sequential(OrderedDict([
            ('conv4', nn.Conv2d(F1 * D, F2, (1, 1), bias=False)),
            ('bn4', nn.BatchNorm2d(F2) if self.eeg_config.use_batch_norm else nn.Identity()),
            ('pool2', nn.AvgPool2d((1, self.eeg_config.pool_size_2))),
            ('dropout2', nn.Dropout(self.eeg_config.dropout_rate)),
        ]))
        
        # ====================================================================
        # Optional Attention
        # ====================================================================
        self.use_attention = self.eeg_config.use_attention
        if self.use_attention:
            self.attention = TemporalAttention(F2)
        
        # ====================================================================
        # Quantum Layer
        # ====================================================================
        self.quantum_layer = QuantumLayerMidas(self.quantum_config)
        
        # Calculate feature dimension after convolutions
        self._calculate_conv_output_size()
        
        # ====================================================================
        # Classification Head
        # ====================================================================
        self.classifier = nn.Sequential(OrderedDict([
            ('flatten', nn.Flatten()),
            ('fc1', nn.Linear(
                F2 * self.quantum_config.n_qubits * self.conv_output_length,
                256
            )),
            ('relu', nn.ReLU()),
            ('dropout', nn.Dropout(0.5)),
            ('fc2', nn.Linear(256, self.eeg_config.num_classes)),
        ]))
        
        # ====================================================================
        # Model Metadata
        # ====================================================================
        self.training_steps = 0
        self.feature_importance = None
        
        # Initialize weights
        self._initialize_weights()
    
    def _calculate_conv_output_size(self):
        """Calculate output size after convolutions"""
        # Create dummy input
        dummy_input = torch.randn(1, 1, self.input_channels, self.input_length)
        
        # Forward through conv layers
        x = self.block1(dummy_input)
        x = self._get_activation()(x)
        x = self.block2(x)
        x = self._get_activation()(x)
        x = self.block3_depthwise(x)
        x = self._get_activation()(x)
        x = self.block3_pointwise(x)
        
        # Store output length
        self.conv_output_length = x.size(-1)
    
    def _get_activation(self):
        """Get activation function"""
        activations = {
            'elu': F.elu,
            'relu': F.relu,
            'gelu': F.gelu,
            'swish': lambda x: x * torch.sigmoid(x)
        }
        return activations.get(self.eeg_config.activation, F.elu)
    
    def _initialize_weights(self):
        """Initialize model weights"""
        for m in self.modules():
            if isinstance(m, nn.Conv2d):
                nn.init.kaiming_normal_(m.weight, mode='fan_out', nonlinearity='relu')
            elif isinstance(m, nn.BatchNorm2d):
                nn.init.constant_(m.weight, 1)
                nn.init.constant_(m.bias, 0)
            elif isinstance(m, nn.Linear):
                nn.init.xavier_normal_(m.weight)
                if m.bias is not None:
                    nn.init.constant_(m.bias, 0)
    
    def forward(self, x, return_features: bool = False):
        """
        Forward pass
        
        Args:
            x: Input tensor (batch, 1, channels, time)
            return_features: If True, return intermediate features
            
        Returns:
            logits or (logits, features) if return_features=True
        """
        features = {}
        activation = self._get_activation()
        
        # Block 1: Temporal
        x = self.block1(x)
        x = activation(x)
        features['temporal'] = x
        
        # Block 2: Spatial
        x = self.block2(x)
        x = activation(x)
        features['spatial'] = x
        
        # Block 3: Separable
        x = self.block3_depthwise(x)
        x = activation(x)
        x = self.block3_pointwise(x)
        x = activation(x)
        features['separable'] = x
        
        # Attention (optional)
        if self.use_attention:
            x = x.squeeze(2)  # Remove spatial dim: (B, C, T)
            x = self.attention(x)
            x = x.unsqueeze(2)  # Add back: (B, C, 1, T)
        
        # Quantum processing
        batch_size = x.size(0)
        x = x.squeeze(2)  # (B, F2, T)
        
        # Process each channel through quantum layer
        quantum_outputs = []
        for i in range(x.size(1)):
            channel_data = x[:, i, :]  # (B, T)
            
            # Take first n_qubits time points
            if channel_data.size(1) >= self.quantum_config.n_qubits:
                channel_input = channel_data[:, :self.quantum_config.n_qubits]
            else:
                # Pad if necessary
                channel_input = F.pad(
                    channel_data,
                    (0, self.quantum_config.n_qubits - channel_data.size(1))
                )
            
            quantum_out = self.quantum_layer(channel_input)  # (B, n_qubits)
            quantum_outputs.append(quantum_out)
        
        x = torch.stack(quantum_outputs, dim=1)  # (B, F2, n_qubits)
        features['quantum'] = x
        
        # Reshape for classification
        x = x.view(batch_size, -1)  # (B, F2 * n_qubits)
        
        # Expand to match expected input size
        if x.size(1) < self.eeg_config.F2 * self.quantum_config.n_qubits * self.conv_output_length:
            repeat_factor = (self.eeg_config.F2 * self.quantum_config.n_qubits * self.conv_output_length) // x.size(1) + 1
            x = x.repeat(1, repeat_factor)[:, :self.eeg_config.F2 * self.quantum_config.n_qubits * self.conv_output_length]
        
        # Classification
        logits = self.classifier(x)
        
        self.training_steps += 1
        
        if return_features:
            return logits, features
        return logits
    
    def get_model_info(self) -> Dict:
        """Get comprehensive model information"""
        total_params = sum(p.numel() for p in self.parameters())
        trainable_params = sum(p.numel() for p in self.parameters() if p.requires_grad)
        quantum_params = sum(p.numel() for p in self.quantum_layer.parameters())
        
        return {
            'model_name': 'QuantumEEGNet-Midas',
            'total_parameters': total_params,
            'trainable_parameters': trainable_params,
            'quantum_parameters': quantum_params,
            'classical_parameters': total_params - quantum_params,
            'input_shape': (1, self.input_channels, self.input_length),
            'output_classes': self.eeg_config.num_classes,
            'quantum_circuit': self.quantum_config.circuit_type,
            'n_qubits': self.quantum_config.n_qubits,
            'n_quantum_layers': self.quantum_config.n_layers,
            'training_steps': self.training_steps,
            'eeg_config': self.eeg_config.__dict__,
            'quantum_config': self.quantum_config.__dict__,
        }
    
    def print_model_summary(self):
        """Print beautiful model summary"""
        info = self.get_model_info()
        
        print("=" * 70)
        print("✨ QuantumEEGNet - Midas Touch Edition ✨")
        print("=" * 70)
        print(f"Total Parameters:      {info['total_parameters']:,}")
        print(f"Trainable Parameters:  {info['trainable_parameters']:,}")
        print(f"Quantum Parameters:    {info['quantum_parameters']:,}")
        print(f"Classical Parameters:  {info['classical_parameters']:,}")
        print(f"\nInput Shape:          {info['input_shape']}")
        print(f"Output Classes:        {info['output_classes']}")
        print(f"\nQuantum Circuit:      {info['quantum_circuit']}")
        print(f"Qubits:               {info['n_qubits']}")
        print(f"Quantum Layers:       {info['n_quantum_layers']}")
        print(f"Training Steps:       {info['training_steps']}")
        print("=" * 70)
    
    def count_parameters(self) -> int:
        """Count trainable parameters"""
        return sum(p.numel() for p in self.parameters() if p.requires_grad)
    
    def freeze_classical(self):
        """Freeze classical parameters, train only quantum"""
        for param in self.parameters():
            param.requires_grad = False
        for param in self.quantum_layer.parameters():
            param.requires_grad = True
    
    def freeze_quantum(self):
        """Freeze quantum parameters, train only classical"""
        for param in self.quantum_layer.parameters():
            param.requires_grad = False
    
    def unfreeze_all(self):
        """Unfreeze all parameters"""
        for param in self.parameters():
            param.requires_grad = True


