def _check_status(self, short=False, verbose=False):
    conf = ScarConfig()
    if not os.path.exists(self.pidfile):
        print(f"{COLOR_RED}Daemon is not running (no PID file).{COLOR_RESET}")
        return

    try:
        with open(self.pidfile) as f:
            pid = int(f.read().strip())

        os.kill(pid, 0)

        # Determine lock status
        lock_status = "missing"
        if os.path.exists(conf.LOCK):
            with open(conf.LOCK) as f:
                owner = f.read().strip()
            lock_status = "valid" if owner == conf.LOCK_OWNER else f"owned by {owner}"

        color = COLOR_GREEN if lock_status == "valid" else COLOR_YELLOW if lock_status != "missing" else COLOR_RED

        if short:
            print(f"{COLOR_GREEN}PID: {pid}{COLOR_RESET}")
            print(f"{color}Lock Status: {lock_status}{COLOR_RESET}")
            return

        scar_hash = compute_hash(conf.FILE) if os.path.exists(conf.FILE) else "<missing>"
        log_mtime = os.path.getmtime(conf.LOG_FILE) if os.path.exists(conf.LOG_FILE) else None
        ts = datetime.fromtimestamp(log_mtime).strftime('%Y-%m-%d %H:%M:%S') if log_mtime else 'N/A'

        # Count and classify tamper logs
        info_count = warning_count = critical_count = 0
